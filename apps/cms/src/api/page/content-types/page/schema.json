{
  "kind": "collectionType",
  "collectionName": "pages",
  "info": {
    "singularName": "page",
    "pluralName": "pages",
    "displayName": "Page"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "template": {
      "type": "enumeration",
      "enum": ["home", "generic"],
      "default": "generic",
      "required": true
    },
    "blocks": {
      "type": "dynamiczone",
      "components": ["page.hero-home"],
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    }
  }
}