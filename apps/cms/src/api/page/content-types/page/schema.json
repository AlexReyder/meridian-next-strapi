{
  "kind": "collectionType",
  "collectionName": "pages",
  "info": {
    "singularName": "page",
    "pluralName": "pages",
    "displayName": "Page",
    "description": "Localized pages assembled from reusable and page-specific blocks"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "template": {
      "type": "enumeration",
      "enum": [
        "home",
        "solutions",
        "for-startups",
        "for-agencies",
        "pricing",
        "method",
        "concepts",
        "get-proposal",
        "landing",
        "generic"
      ],
      "default": "generic",
      "required": true
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "blocks": {
      "type": "dynamiczone",
      "components": [
        "page.hero-home",
        "page.hero",
        "page.rich-text",
        "page.media-text",
        "page.cards-grid",
        "page.video-section",
        "page.steps",
        "page.statements-strip",
        "page.concept-nav",
        "page.concept-section",
        "page.faq",
        "page.cta",
        "page.form-section"
      ],
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    }
  }
}
