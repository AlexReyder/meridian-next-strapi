{
  "kind": "collectionType",
  "collectionName": "pages",
  "info": {
    "singularName": "page",
    "pluralName": "pages",
    "displayName": "Page",
    "description": "Localized pages assembled from Home page specific blocks"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "template": {
      "type": "enumeration",
      "enum": ["home"],
      "default": "home",
      "required": true
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "blocks": {
      "type": "dynamiczone",
      "components": [
        "page.hero-home",
        "page.value-home",
        "page.deliverables-home",
        "page.why-home",
        "page.audience-home",
        "page.concepts-home",
        "page.method-home",
        "page.pricing-home",
        "page.proposal-home",
        "page.sample-preview-home",
        "page.trust-home",
        "page.faq-home",
        "page.final-cta-home"
      ],
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    }
  }
}
